{
  "expo": {
    "name": "OURTH",
    "slug": "ourth-mobile",
    "owner": "sahilbhargava.dev",
    "scheme": "ourth",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logohoilp.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "bundleIdentifier": "com.ourth.mobile",
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/logohoilp.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.ourth.mobile"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font",
      [
        "expo-notifications",
        {
          "icon": "./assets/logohoilp.png",
          "color": "#1a6b5a",
          "sounds": []
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "0ef9b4cd-dd68-4484-8ac8-558383b0b8ad"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/0ef9b4cd-dd68-4484-8ac8-558383b0b8ad"
    }
  }
}
